{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Decision Log Entry Frontmatter",
  "description": "Ensures every decision log entry exposes the metadata contract required by the governance automation.",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 5
    },
    "artifact_type": {
      "const": "decision_log_entry"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "proposal",
        "under review",
        "accepted",
        "superseded"
      ]
    },
    "visibility": {
      "type": "string"
    },
    "classification": {
      "type": "string",
      "enum": [
        "public",
        "public-redacted",
        "private"
      ]
    },
    "owner": {
      "type": "string"
    },
    "review_cadence": {
      "type": "string"
    },
    "applies_to": {
      "type": "string"
    },
    "source_basis": {
      "type": "string"
    },
    "source_manifests": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "alignment_mode": {
      "type": "string"
    },
    "updated": {
      "type": "string",
      "format": "date"
    },
    "decision_log_id": {
      "type": "string",
      "pattern": "^DL-\\d{4}$"
    },
    "decision_date": {
      "type": "string",
      "format": "date"
    },
    "linked_adr": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "artifact_type",
    "status",
    "visibility",
    "classification",
    "owner",
    "review_cadence",
    "applies_to",
    "source_basis",
    "source_manifests",
    "alignment_mode",
    "updated",
    "decision_log_id",
    "decision_date"
  ],
  "additionalProperties": true
}
